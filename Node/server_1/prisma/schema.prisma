// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "sqlite"
}

model Airport {
  id       String @id // was `code: AirportCode` — IATA code is the identity
  name     String
  city     String
  country  String
  timezone String

  // `futureFlights` from the interface maps to departing flights; the
  // "future" date filter stays in app logic, not the schema. Both
  // back-relations are required because Flight has two FKs to Airport.
  departingFlights Flight[] @relation("DepartingFlights")
  arrivingFlights  Flight[] @relation("ArrivingFlights")

  // Reroutes whose new destination is this airport (3rd relation to Airport).
  rerouteDestinations FlightReroute[] @relation("RerouteDestination")
}

model Flight {
  id                Int      @id @default(autoincrement())
  source            String // FK -> Airport.id (departure)
  destination       String // FK -> Airport.id (arrival)
  dateTimeDeparture DateTime
  dateTimeLanding   DateTime
  airline           String
  flightNumber      String

  sourceAirport      Airport @relation("DepartingFlights", fields: [source], references: [id])
  destinationAirport Airport @relation("ArrivingFlights", fields: [destination], references: [id])

  // Append-only disruption history; both cascade so deleting a flight clears its events.
  delays   FlightDelay[]   @relation("FlightDelays")
  reroutes FlightReroute[] @relation("FlightReroutes")
}

// Append-only record of a rescheduled flight: a new departure/landing pair and a
// free-text reason. The original Flight row is never mutated; the latest delay
// (by createdAt) is the effective schedule.
model FlightDelay {
  id                Int      @id @default(autoincrement())
  flightId          Int // FK -> Flight.id
  dateTimeDeparture DateTime // new scheduled departure
  dateTimeLanding   DateTime // new scheduled landing
  reason            String
  createdAt         DateTime @default(now())

  flight Flight @relation("FlightDelays", fields: [flightId], references: [id], onDelete: Cascade)

  @@index([flightId])
}

// Append-only record of a flight diverted to a different destination airport.
// The original Flight row is never mutated; newDestination references Airport.id.
model FlightReroute {
  id             Int      @id @default(autoincrement())
  flightId       Int // FK -> Flight.id
  newDestination String // FK -> Airport.id
  reason         String
  createdAt      DateTime @default(now())

  flight                Flight  @relation("FlightReroutes", fields: [flightId], references: [id], onDelete: Cascade)
  newDestinationAirport Airport @relation("RerouteDestination", fields: [newDestination], references: [id], onDelete: Restrict)

  @@index([flightId])
  @@index([newDestination])
}
